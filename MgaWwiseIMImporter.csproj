<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>MgaWwiseIMImporter</RootNamespace>
    <AssemblyName>MgaWwiseIMImporter</AssemblyName>
    <Product>MGA Wwise IMImporter</Product>
    <ApplicationTitle>MGA Wwise IMImporter</ApplicationTitle>
    <ApplicationIcon>Assets\Branding\MgaWwiseIMImporter.ico</ApplicationIcon>
    <Version>1.0.1-beta</Version>
    <AssemblyVersion>1.0.1.0</AssemblyVersion>
    <FileVersion>1.0.1.0</FileVersion>
    <InformationalVersion>1.01 β</InformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- ローカル検証用スクラッチを既定グロブから除外する -->
    <Compile Remove="_probe\**" />
    <None Remove="_probe\**" />
  </ItemGroup>

  <!-- 色調整パネルは開発ビルド専用。Release バイナリには含めない。 -->
  <ItemGroup Condition="'$(Configuration)' == 'Release'">
    <Compile Remove="UI\ColorDevPanelForm.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

  <ItemGroup>
    <!-- SIL Open Font License 1.1。フォント本体とライセンスを必ず一緒に配布する。 -->
    <None Update="Assets\Fonts\UDEVGothic-Regular.ttf">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>Fonts\UDEVGothic-Regular.ttf</TargetPath>
    </None>
    <None Update="Assets\Fonts\LICENSE-UDEV-GOTHIC.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>Fonts\LICENSE-UDEV-GOTHIC.txt</TargetPath>
    </None>
    <None Update="Assets\Branding\MiyabiGameAudio.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>Branding\MiyabiGameAudio.png</TargetPath>
    </None>
    <None Update="Assets\Branding\MgaWwiseIMImporter.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>Branding\MgaWwiseIMImporter.ico</TargetPath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="UI\Form1.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="UI\Form1.Designer.cs">
      <DependentUpon>Form1.cs</DependentUpon>
    </Compile>
  </ItemGroup>

</Project>
